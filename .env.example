# App server port
PORT=3000

# Runtime mode used by run.sh
NODE_ENV=development

# SQLite database file path
DATABASE_PATH=./data/app.db

# Auth session lifetime in milliseconds
AUTH_SESSION_TTL_MS=604800000

# Search response cache lifetime in milliseconds
SEARCH_CACHE_TTL_MS=300000

# Default admin account created on boot if missing
DEFAULT_ADMIN_EMAIL=admin@local.dev
DEFAULT_ADMIN_PASSWORD=admin123456

# Credits granted to each normal user once per calendar month
DEFAULT_MONTHLY_CREDITS=150

# Optional outbound proxy for DuckDuckGo browser traffic
# Examples:
# PROXY_SERVER=http://127.0.0.1:8080
# PROXY_SERVER=socks5://127.0.0.1:1080
PROXY_SERVER=

# Optional proxy authentication
PROXY_USERNAME=
PROXY_PASSWORD=

# Optional proxy bypass list passed to Chromium
# Example: localhost;127.0.0.1;*.internal.local
PROXY_BYPASS=
